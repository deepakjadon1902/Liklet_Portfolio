MONGODB_URI=mongodb+srv://...
JWT_SECRET=change-me

# Optional: Allowed frontend origins (comma-separated)
# CORS_ORIGIN=http://localhost:8080,https://liklet-portfolio.vercel.app

# Google Auth (required for user login)
# GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# Optional (recommended in production): backend public base URL for redirect URI generation
# PUBLIC_BASE_URL=https://liklet-portfolio-2.onrender.com
# Optional (recommended): frontend base URL for redirect back after Google auth
# FRONTEND_URL=https://liklet-portfolio.vercel.app

# Razorpay (required for checkout)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# Optional FX rate (used when charging USD)
# FX_INR_TO_USD=0.012

# Optional contact email (comma-separated). Falls back to ADMIN_EMAILS if set.
# CONTACT_EMAILS=mail.liklet@gmail.com

# SMTP (optional; if unset, emails are logged to console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# EMAIL_FROM=mail.liklet@gmail.com

# Static admin credentials (defaults used if unset)
# ADMIN_STATIC_EMAIL=liket108admin@gmail.com
# ADMIN_STATIC_PASSWORD=liket108admin@

# Seed default social-media services/packages on startup
# SEED_DEFAULTS=true
