# API base URL for the frontend to call the backend.
# In dev, Vite also proxies `/api` -> `http://localhost:5000` (see `vite.config.ts`).
VITE_API_BASE_URL=/api

# Optional FX rate (used for USD display)
# VITE_FX_INR_TO_USD=0.012

# Google Identity Services (to render the official Google button on /auth)
# VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
